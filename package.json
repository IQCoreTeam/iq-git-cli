{
  "name": "@iqlabs-official/git",
  "version": "0.1.0",
  "description": "On-chain Git for Solana — version control stored entirely on-chain via IQLabs SDK",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/web3.js": "^1.98.0",
    "ignore": "^7.0.5",
    "iqlabs-sdk": "npm:@iqlabs-official/solana-sdk@^0.1.21"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/IQCoreTeam/iq-git"
  },
  "license": "MIT",
  "keywords": [
    "solana",
    "git",
    "on-chain",
    "iqlabs",
    "version-control",
    "decentralized"
  ]
}
